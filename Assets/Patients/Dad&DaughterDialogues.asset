  m_Name: Dad&DaughterDialogues
  m_EditorClassIdentifier: 
  personalityNote: 
  sequences:
  - sequenceID: onOpen_Day1
    lines:
    - line: "I know I\u2019m in critical state."
      portrait: {fileID: -5556050023837524733, guid: 9f2760b870789c54da2874bf53f850ae, type: 3}
    - line: This ranking system is absurd.
      portrait: {fileID: 1826077327187480495, guid: 212bfb78c30e3124e85262e682eb0aad, type: 3}
    - line: I demand my daughter be treated at any cost.
      portrait: {fileID: 7986923097283423509, guid: 2ff33ef6316762045a20b72a3108b37e, type: 3}
    - line: I will only be admitted if you treat my daughter too.
      portrait: {fileID: -5556050023837524733, guid: 9f2760b870789c54da2874bf53f850ae, type: 3}
  - sequenceID: onDeny_Day1_1
    lines:
    - line: 'I thought this place helped people.

'
      portrait: {fileID: -3127505059345813034, guid: c80ca50a717b2c64390c20e158ab2e4f, type: 3}
    - line: "\u2026but I guess it just decides."
      portrait: {fileID: 1826077327187480495, guid: 212bfb78c30e3124e85262e682eb0aad, type: 3}
  - sequenceID: onDeny_Day2_1
    lines:
    - line: Please, my daughter needs help. I cannot watch her suffer like this.
      portrait: {fileID: -3127505059345813034, guid: c80ca50a717b2c64390c20e158ab2e4f, type: 3}
