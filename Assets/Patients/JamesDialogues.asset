  m_Script: {fileID: 11500000, guid: e88d9c26c071469419d3a276e7805658, type: 3}
  m_Name: JamesDialogues
  m_EditorClassIdentifier: 
  personalityNote: 
  sequences:
  - sequenceID: onOpen_Day1
    lines:
    - line: Excuse me, mister?
      portrait: {fileID: -8408129490410009404, guid: 8b94669867145ff40be9ebc65632b0e8, type: 3}
    - line: 'Are mommy and daddy here? '
      portrait: {fileID: -8408129490410009404, guid: 8b94669867145ff40be9ebc65632b0e8, type: 3}
    - line: They haven't been home in 3 days.
      portrait: {fileID: -8408129490410009404, guid: 8b94669867145ff40be9ebc65632b0e8, type: 3}
    - line: My tummy hurts a lot and I need mommy right now.
      portrait: {fileID: -8408129490410009404, guid: 8b94669867145ff40be9ebc65632b0e8, type: 3}
    - line: Mrs Madison told me to come here.
      portrait: {fileID: -8408129490410009404, guid: 8b94669867145ff40be9ebc65632b0e8, type: 3}
  - sequenceID: onAdmit
    lines:
    - line: Thank you, mister.
      portrait: {fileID: -8408129490410009404, guid: 8b94669867145ff40be9ebc65632b0e8, type: 3}
  - sequenceID: onDeny_Day1
    lines:
    - line: But it hurts and mommy always takes me here to make it stop. I miss my
        mommy.
      portrait: {fileID: -8408129490410009404, guid: 8b94669867145ff40be9ebc65632b0e8, type: 3}
