  sequences:
  - sequenceID: onOpen_Day1
    lines:
    - line: "Hey\u2026 I\u2019ll keep this quick."
      portrait: {fileID: 3908291731744268417, guid: c86053ba0e11c0e4781cc3299073fce0, type: 3}
    - line: "Been driving most of the night. Haven\u2019t really stopped."
      portrait: {fileID: -7745866838023387807, guid: 1ed5b616b561bf34aa7a2793dc5cc2c8, type: 3}
    - line: "They\u2019ve got me running supplies between campus."
      portrait: {fileID: 3908291731744268417, guid: c86053ba0e11c0e4781cc3299073fce0, type: 3}
    - line: "If I miss the next run, they\u2019ll have to wait till morning.\r\n"
      portrait: {fileID: 3908291731744268417, guid: c86053ba0e11c0e4781cc3299073fce0, type: 3}
  - sequenceID: onDeny_Day1_1
    lines:
    - line: I'll manage
      portrait: {fileID: -1311541229341687916, guid: 574cd9e50c3917642b1d479682541546, type: 3}
  - sequenceID: onAdmit
    lines:
    - line: Alright
