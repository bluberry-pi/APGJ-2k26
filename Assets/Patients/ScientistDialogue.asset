  sequences:
  - sequenceID: onOpen_Day1
    lines:
    - line: I was part of the team studying the refinery leak.
      portrait: {fileID: -6118522970096299973, guid: acb7627b44d9c054191cb4280b9fcc79, type: 3}
    - line: "Trust me, all of this\u2026is a very convenient coverup by the govt"
      portrait: {fileID: -6118522970096299973, guid: acb7627b44d9c054191cb4280b9fcc79, type: 3}
    - line: No one gets it, factory leaks won't cause pandemics
      portrait: {fileID: -6118522970096299973, guid: acb7627b44d9c054191cb4280b9fcc79, type: 3}
    - line: Exposure levels were higher than expected
      portrait: {fileID: -6118522970096299973, guid: acb7627b44d9c054191cb4280b9fcc79, type: 3}
    - line: My Symptoms started this morning
      portrait: {fileID: -6118522970096299973, guid: acb7627b44d9c054191cb4280b9fcc79, type: 3}
  - sequenceID: onDeny_Day1
    lines:
    - line: 'Please, i dont wanna die like this

'
