  sequences:
  - sequenceID: onOpen_Day1
    lines:
    - line: "Spinal injury\u2026 that\u2019s what they said."
      portrait: {fileID: 0}
    - line: convenient, considering I passed out.
      portrait: {fileID: 0}
    - line: that factory never felt right
      portrait: {fileID: 0}
    - line: They said my tier would be demoted
      portrait: {fileID: 0}
    - line: As i can no longer walk...
      portrait: {fileID: 0}
  - sequenceID: onDeny_Day1
    lines:
    - line: Consider it again, i dont wanna die like this.
      portrait: {fileID: 0}
  - sequenceID: onDeny_Day1
    lines:
    - line: Carful warden, the system only keeps its monsters until it runs out of
        meat
      portrait: {fileID: 0}
  - sequenceID: onAdmit
    lines:
    - line: I hope i survive long enough to discover my truth
      portrait: {fileID: 0}
