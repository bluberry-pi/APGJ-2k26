      m_Calls: []
  m_text: "\u201CWecome, Warden.\u201D\nThe Weeks of Collapse left this country starving
    of resources, time, and mercy.\n\nYou\u2019ve been assigned to manage wlhat remains.\n\nNot
    everyone can be saved.\n\nTier 1 patients bring in the most value. Losing them
    is\u2026 expensive.\nEvery death increases your Death Value. Keep count of it,
    you wont be notified.\n\nTier 1: +30\nTier 2: +20\nTier 3: +10\n\nIf your Death
    Value exceeds 50, you will be replaced.\n\nChoose carefully.\nSome lives are
    worth more than others.\n\nGood luck to you\u2026and your family."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 028c245f03387184481aeba2725267af, type: 2}
